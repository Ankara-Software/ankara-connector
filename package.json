{
  "name": "ankara-connector",
  "version": "2.0.0",
  "description": "Ankara Yazılım Connector — fiziksel donanımı panellerle köprüleyen headless agent.",
  "type": "module",
  "private": true,
  "bin": {
    "ankara-connector": "src/index.ts"
  },
  "scripts": {
    "build": "cargo build --release -p connector-app",
    "build:windows": "bun run scripts/build-windows.ts",
    "build:legacy": "bun run scripts/build.ts",
    "start": "bun run src/index.ts run",
    "pair": "bun run src/index.ts pair",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "1.3.14",
    "pngjs": "^7.0.0",
    "rcedit": "^5.0.2",
    "to-ico": "^1.1.0",
    "typescript": "~5.8.3"
  }
}
